# Copy to `.env.local` for local overrides (do not commit secrets).

# Empty = same-origin `/api/v1` (Vite dev proxy → localhost:3000). Set to hit a remote API:
# VITE_API_BASE_URL=https://bingora-backend-production.up.railway.app:5173/api/v1
#
# Railway costuma expor HTTPS na porta 443; se :5173 não responder, tente sem porta.
VITE_API_BASE_URL=

# true = in-memory mock API (no backend). false = real API.
VITE_USE_MOCK_API=false
